    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 13
    btn.Parent = cdC
    addCorner(btn, 8)
    
    if time == 120 then 
        btn.BackgroundColor3 = Color3.fromRGB(20, 120, 60)
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    end
    
    btn.MouseButton1Click:Connect(function()
        cooldownTime = time
        for _, b in pairs(cdButtons) do
            tween(b, 0.2, {BackgroundColor3 = Color3.fromRGB(40, 40, 70), TextColor3 = Color3.fromRGB(200, 200, 220)})
        end
        tween(btn, 0.2, {BackgroundColor3 = Color3.fromRGB(20, 120, 60), TextColor3 = Color3.fromRGB(255, 255, 255)})
    end)
     
    table.insert(cdButtons, btn)
    return btn
end

