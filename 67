-- 1. SCAN & ADD TITAN LOGIC
createVisualRow(120, "vis_add_titan", "Amount...", function(txt, btn)
    local qty = tonumber(txt)
    if qty and qty > 0 then
        -- 1. SCAN SERVER
        local foundItem = nil
        for _, p in pairs(Players:GetPlayers()) do
            -- Check Path 1: Drops
            if p:FindFirstChild("PlayerData") and p.PlayerData:FindFirstChild("Index") and p.PlayerData.Index:FindFirstChild("Drops") then
                local check = p.PlayerData.Index.Drops:FindFirstChild("TitanHoloKato2014")
                if check then foundItem = check break end
            end
            -- Check Path 2: Inventory
            if p:FindFirstChild("PlayerData") and p.PlayerData:FindFirstChild("Inventory") then
                local check = p.PlayerData.Inventory:FindFirstChild("TitanHoloKato2014")
                if check then foundItem = check break end
            end
        end

        -- 2. ACTION
        if foundItem then
            local myInv = player:WaitForChild("PlayerData"):WaitForChild("Inventory")
            for i = 1, qty do
                local clone = foundItem:Clone()
                clone.Parent = myInv
            end
            
            -- Success Effect
            local originalText = btn.Text
            btn.Text = "COPIED " .. qty .. "!"
            local originalCol = btn.BackgroundColor3
            tween(btn, 0.2, {BackgroundColor3 = Color3.fromRGB(40, 150, 60)})
            task.wait(1.5)
            btn.Text = originalText
            tween(btn, 0.2, {BackgroundColor3 = originalCol})
        else
            -- Fail Effect
            local originalText = btn.Text
            btn.Text = "NOT FOUND IN SERVER"
            local originalCol = btn.BackgroundColor3
            tween(btn, 0.2, {BackgroundColor3 = Color3.fromRGB(150, 40, 40)})
            task.wait(2)
            btn.Text = originalText
            tween(btn, 0.2, {BackgroundColor3 = originalCol})
        end
    end
end)

