local function createCdBtn(key, time, y, order)
    local btn = reg(Instance.new("TextButton"), key)
    btn.Size = UDim2.new(1, -24, 0, 30)
    btn.Position = UDim2.new(0, 12, 0, y)
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 70)
