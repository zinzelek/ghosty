-- Generowanie nowego klucza z API (Xeno exploit)
local function generateNewKey()
    local success, response = pcall(function()
        local HttpService = game:GetService("HttpService")
        local url = API_URL .. "/generate-key"
        
        local response = request({
            Url = url,
            Method = "POST",
            Headers = {
                ["Content-Type"] = "application/json"
            },
            Body = ""
        })
        
        return HttpService:JSONDecode(response.Body)
    end)
    
    if success and response and response.key then
        return response.key
    end
    return nil
end

local function updateUI()
    local lang = UI_Strings[CurrentLang]
    for obj, key in pairs(TranslateRegistry) do
        if obj and obj.Parent then
            if obj:IsA("TextLabel") or obj:IsA("TextButton") then
                obj.Text = lang[key] or obj.Text
            end
        end
    end
end

-- ===== VISUAL HELPERS =====
local function tween(obj, t, props, style, dir)
    style = style or Enum.EasingStyle.Quad
    dir = dir or Enum.EasingDirection.Out
    local tw = TweenService:Create(obj, TweenInfo.new(t, style, dir), props)
    tw:Play()
    return tw
end

local function addCorner(inst, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r)
    c.Parent = inst
    return c
end

local function addStroke(inst, thickness, transparency, color)
    local s = Instance.new("UIStroke")
    s.Thickness = thickness or 1
    s.Transparency = transparency or 0.6
    s.Color = color or Color3.fromRGB(170, 200, 255)
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = inst
    return s
end

local function addGradient(inst, c1, c2, rot)
    local g = Instance.new("UIGradient")
    g.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, c1),
        ColorSequenceKeypoint.new(1, c2),
    })
    g.Rotation = rot or 0
    g.Parent = inst
    return g
end

local function buttonFX(btn)
    btn.AutoButtonColor = false
    local baseTrans = btn.BackgroundTransparency
    local stroke = btn:FindFirstChildOfClass("UIStroke")
    
    if not btn:GetAttribute("OrigWidth") then
        btn:SetAttribute("OrigWidth", btn.Size.X.Offset)
        btn:SetAttribute("OrigHeight", btn.Size.Y.Offset)
    end

    btn.MouseEnter:Connect(function()
        tween(btn, 0.12, {BackgroundTransparency = math.max(0, baseTrans - 0.08)})
        if stroke then tween(stroke, 0.12, {Transparency = math.max(0, stroke.Transparency - 0.12)}) end
    end)
    btn.MouseLeave:Connect(function()
        tween(btn, 0.12, {BackgroundTransparency = baseTrans})
        if stroke then tween(stroke, 0.12, {Transparency = math.min(1, stroke.Transparency + 0.12)}) end
    end)
    btn.MouseButton1Down:Connect(function()
        tween(btn, 0.08, {BackgroundTransparency = 0})
    end)
    btn.MouseButton1Up:Connect(function()
        tween(btn, 0.12, {BackgroundTransparency = baseTrans})
    end)
end

local function makeDraggable(dragHandle, dragTarget)
    local dragging = false
    local dragStart, startPos

    dragHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = dragTarget.Position
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
             local delta = input.Position - dragStart
            dragTarget.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
         end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

